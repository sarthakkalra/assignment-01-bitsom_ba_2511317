# =========================================
# Imports
# =========================================
from sentence_transformers import SentenceTransformer
from sklearn.metrics.pairwise import cosine_similarity
import seaborn as sns
import matplotlib.pyplot as plt
import numpy as np

# =========================================
# Define Sentences (10 total, 3 topics)
# =========================================
sentences = [
    # Cricket (4)
    "The batsman scored a century in the match",
    "The bowler delivered a fast yorker",
    "India won the cricket series convincingly",
    "The fielders saved crucial runs near the boundary",

    # Cooking (3)
    "Add spices to enhance the flavor of the dish",
    "The recipe requires fresh vegetables and herbs",
    "Boil the pasta until it becomes soft",

    # Cybersecurity (3)
    "Strong passwords are essential for online security",
    "Cyber attacks can compromise sensitive data",
    "Encryption helps protect confidential information"
]

# =========================================
# Load Model & Generate Embeddings
# =========================================
model = SentenceTransformer('all-MiniLM-L6-v2')
embeddings = model.encode(sentences)

# =========================================
# Compute Cosine Similarity Matrix
# =========================================
similarity_matrix = cosine_similarity(embeddings)

print("Similarity Matrix Shape:", similarity_matrix.shape)

# =========================================
# Plot Heatmap
# =========================================
plt.figure(figsize=(10, 8))
sns.heatmap(similarity_matrix, annot=True, cmap='coolwarm', xticklabels=False, yticklabels=False)
plt.title("Cosine Similarity Heatmap")
plt.show()

# =========================================
# Query Similarity Search
# =========================================
query = "The bowler took three wickets in one over"

query_embedding = model.encode([query])
similarities = cosine_similarity(query_embedding, embeddings)[0]

# Get top 2 similar sentences
top_indices = np.argsort(similarities)[-2:][::-1]

print("\nQuery:", query)
print("\nTop 2 Similar Sentences:")

for idx in top_indices:
    print(f"\nSentence: {sentences[idx]}")
    print(f"Similarity Score: {similarities[idx]:.4f}")